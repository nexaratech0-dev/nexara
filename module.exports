# .github/workflows/frontend-ci.yml
cat > .github/workflows/frontend-ci.yml <<'EOF'
name: Frontend CI

on:
  push:
    branches: [ main, feature/initial-scaffold ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ./web
    steps:
      - uses: actions/checkout@v4
      - name: Use Node
        uses: actions/setup-node@v4
        with:
          node-version: 18
          cache: 'pnpm'
      - name: Install pnpm
        run: |
          corepack enable
          corepack prepare pnpm@8.9.0 --activate
      - name: Install deps
        run: pnpm install
      - name: Typecheck
        run: pnpm build --dry-run || true
      - name: Lint
        run: pnpm lint || true
      - name: Run tests
        run: pnpm test || true
      - name: Build Storybook
        run: pnpm build-storybook || true
EOF

# Root README.md (replace)
cat > README.md <<'EOF'
# nexara

Nexara — Intelligent, composable AI interfaces for teams and customers.

Overview
Nexara is a platform for building enterprise-grade AI interfaces: conversational agents, prompt playgrounds, model management, and observability — with a focus on security, control, and extensibility.

Key Features
- Conversational UI with streaming LLM responses
- Prompt & template management
- Model registry and metrics
- RBAC and SSO support
- Analytics, cost monitoring, and audit logs
- Integrations (webhooks, Slack, REST API)

Getting started (developer)
1. Clone the repo:
   git clone https://github.com/nexaratech0-dev/nexara.git
2. Frontend:
   - Recommended: Node 18+, pnpm
   - cd web && pnpm install && pnpm dev
3. Backend:
   - cd api && pnpm install && pnpm dev
4. Configure environment:
   - Copy `.env.example` to `.env` and fill in provider keys, DB connection, and SSO settings.
5. Run migrations and seed data (if included).

Design & Development
- UI: React + TypeScript, Storybook for components
- Backend: Node.js (NestJS recommended), PostgreSQL, Redis
- Model adapters to integrate with OpenAI / Anthropic / Azure OpenAI or local models

Contributing
- Follow the code style in `.editorconfig` and `eslint` rules
- Add Storybook stories for new components
- Open a PR with clear description, screenshots, and test coverage where applicable

License
TBD — add a license file (e.g., MIT) to the repo.

Contact
For design files, questions, or to request Figma/Storybook artifacts, open an issue or contact the maintainers.
EOF

# Stage and commit
git add -A
git commit -m "chore(scaffold): add frontend scaffold (Next.js, Tailwind, Storybook)"
echo "Pushing branch ${BRANCH} to origin..."
git push -u origin "${BRANCH}"

echo
echo "Done. Files have been written and pushed to branch: ${BRANCH}"
echo "Next steps:"
echo "  - Open a Pull Request on GitHub from ${BRANCH} -> main"
echo "  - Or use the GitHub CLI: gh pr create --base main --head ${BRANCH} --title \"chore(scaffold): add frontend scaffold\" --body \"Adds Next.js frontend scaffold, Storybook, ChatWidget demo, and CI workflow.\""
echo
echo "If push failed due to permissions, ensure you have write access or run this script locally from a clone where you can push."
