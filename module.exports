#!/usr/bin/env bash
set -euo pipefail

REPO_URL="https://github.com/nexaratech0-dev/nexara.git"
BRANCH_BASE="feature/initial-scaffold"
WORKDIR="${PWD}"
CLONE_DIR="nexara"

# If inside a git repo, use current dir if remote matches; otherwise clone
if [ -d ".git" ]; then
  echo "Detected .git in current directory. Using current directory as repo."
  GIT_URL="$(git config --get remote.origin.url || true)"
  if [ -n "$GIT_URL" ] && [[ "$GIT_URL" != "$REPO_URL" ]]; then
    echo "Warning: current repo remote.origin.url is '$GIT_URL' (not $REPO_URL)."
    read -p "Continue using current directory? (y/N) " yn
    case "$yn" in
      [Yy]*) ;;
      *) echo "Abort."; exit 1;;
    esac
  fi
  REPO_DIR="${WORKDIR}"
else
  echo "Cloning repository $REPO_URL into ./${CLONE_DIR}..."
  git clone "$REPO_URL" "$CLONE_DIR"
  REPO_DIR="${WORKDIR}/${CLONE_DIR}"
fi

cd "$REPO_DIR"
git fetch origin --prune

# Determine branch name: if exists, append timestamp
BRANCH="$BRANCH_BASE"
if git rev-parse --verify --quiet "$BRANCH" >/dev/null || git ls-remote --exit-code --heads origin "$BRANCH" >/dev/null 2>&1; then
  TS=$(date +%s)
  BRANCH="${BRANCH_BASE}-${TS}"
  echo "Branch feature/initial-scaffold already exists; using branch ${BRANCH}"
fi

# Create and checkout branch from origin/main (or main)
if git show-ref --verify --quiet refs/heads/main || git ls-remote --exit-code --heads origin main >/dev/null 2>&1; then
  git checkout -b "$BRANCH" origin/main 2>/dev/null || git checkout -b "$BRANCH" main 2>/dev/null || git checkout -b "$BRANCH"
else
  git checkout -b "$BRANCH"
fi

echo "Writing scaffold files..."

# Create directories
mkdir -p web/app/api/mock-stream
mkdir -p web/components
mkdir -p web/styles
mkdir -p web/.storybook
mkdir -p web/stories
mkdir -p .github/workflows

# web/package.json
cat > web/package.json <<'EOF'
{
  "name": "nexara-web",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ext .ts,.tsx .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "next": "14.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "7.0.0",
    "@storybook/react": "7.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "20.5.1",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.48.0",
    "eslint-config-next": "14.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.35",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "5.6.2"
  }
}
EOF

# web/README.md
cat > web/README.md <<'EOF'
# Nexara — Web (frontend)

This folder contains the Next.js + TypeScript frontend scaffold for Nexara.

Quickstart
1. Install (requires Node 18+ and pnpm)
   pnpm install

2. Dev server
   pnpm dev

3. Storybook
   pnpm storybook

4. Build
   pnpm build
   pnpm start

Notes
- The ChatWidget demo on the homepage talks to `/api/mock-stream`, a simple mock SSE route implemented for local development.
- Tailwind is configured; edit tokens in `tailwind.config.js`.
EOF

